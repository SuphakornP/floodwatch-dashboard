# Turso Cloud. Required in production; leave blank for local development SQLite.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Local development fallback only. Ignored when TURSO_DATABASE_URL is set.
DATABASE_FILENAME=floodwatch.sqlite

# Optional: leave blank unless testing browser push notifications.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Optional locally. Use independent, long random values when these routes are enabled.
ALERT_ADMIN_TOKEN=
CRON_SECRET=
